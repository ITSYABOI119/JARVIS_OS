# JARVIS AI-OS .gitignore

# C/C++ compiled files
*.o
*.a
*.so
*.exe
*.out
test_cache
test_ipc
ipc_benchmark

# Build directories
build/
*.build/
cmake-build-*/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv*/
.venv_*/
env/
venv/
ENV/
*.egg-info/
dist/
*.egg

# AI Model files (too large for git - use Git LFS or download separately)
*.gguf
*.bin
*.safetensors
# models/ dir tracked — .gguf files ignored by the pattern above

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Temporary files
*.tmp
temp/
tmp/

# QEMU
*.qcow2
*.img

# seL4 build artifacts
*.elf
*.dump

# Firmware overlays
*.dtbo

# Build artifacts (firmware binaries)
phase2/firmware/kernel8.img
phase2/firmware/jarvis-sel4-image-arm-bcm2711
temp_sd_backup/**/*.img
temp_sd_backup/**/*.elf

# Test binaries
phase3/src/*/test_*
!phase3/src/*/test_*.c

# System files
Thumbs.db
.directory

# Windows device-name accidents
nul
NUL

wikitext-2-raw/

# Crash dumps / agent scratch (clean tree)
bash.exe.stackdump
*.stackdump
.codex/
